{
  "code-runner.runInTerminal": true,
  "liveServer.settings.donotShowInfoMsg": true,
  "explorer.confirmDragAndDrop": false,
  "extensions.ignoreRecommendations": true,
  "extensions.showRecommendationsOnlyOnDemand": true,
  "explorer.confirmDelete": false,
  "json.schemaDownload.enable": false,
  "git.openRepositoryInParentFolders": "never",
  "workbench.colorTheme": "Ayu Dark",
  "workbench.iconTheme": "gruvbox-material-icon-theme",
  "workbench.startupEditor": "none",
  "breadcrumbs.enabled": false,
  "workbench.sideBar.location": "left",
  "workbench.tree.renderIndentGuides": "none",
  "window.customTitleBarVisibility": "never",
  "workbench.tree.indent": 16,
  "explorer.compactFolders": false,
  "editor.fontLigatures": true,
  "editor.fontFamily": "Maple Mono",
  "editor.lineHeight": 2,
  "editor.fontSize": 15,
  "editor.letterSpacing": 0.3,
  "editor.fontWeight": "400",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "comment",
          "variable.parameter",
          "meta.object-literal.key" //for JS and TS object keys
        ],
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },
  "workbench.colorCustomizations": {
    "[Ayu Dark]": {},
    "gitDecoration.modifiedResourceForeground": "#73b8ff",
    "gitDecoration.untrackedResourceForeground": "#7fd962",
    "gitDecoration.addedResourceForeground": "#81b88b",
    "editorOverviewRuler.addedForeground": "#0000",
    "editorOverviewRuler.modifiedForeground": "#0000",
    "editorOverviewRuler.deletedForeground": "#0000",
    "editorOverviewRuler.infoForeground": "#0000",
    "editorOverviewRuler.warningForeground": "#0000",
    "editorOverviewRuler.errorForeground": "#0000",
    "editorOverviewRuler.bracketMatchForeground": "#0000",
    "editorOverviewRuler.commentForeground": "#0000",
    "editorOverviewRuler.commentUnresolvedForeground": "#0000",
    "editorOverviewRuler.currentContentForeground": "#0000",
    "editorOverviewRuler.commonContentForeground": "#0000",
    "editorOverviewRuler.incomingContentForeground": "#0000",
    "editorOverviewRuler.findMatchForeground": "#0000",
    "editorOverviewRuler.rangeHighlightForeground": "#0000",
    "editorOverviewRuler.selectionHighlightForeground": "#0000",
    "editorOverviewRuler.wordHighlightForeground": "#0000",
    "editorOverviewRuler.wordHighlightStrongForeground": "#0000",
    "editorOverviewRuler.wordHighlightTextForeground": "#0000",
    "panel.border": "#ffffff10",
    "panel.dropBorder": "#0000"
  },
  "workbench.layoutControl.enabled": false,
  "workbench.sash.size": 4,
  // "window.title": "‎",
  "window.commandCenter": false,
  "window.title": "${activeEditorShort}",
  "window.menuBarVisibility": "compact",
  "editor.lightbulb.enabled": "off",
  "editor.snippetSuggestions": "top",
  "editor.selectionHighlight": false,
  "editor.occurrencesHighlight": "off",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "editor.overviewRulerBorder": false,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "emmet.triggerExpansionOnTab": true,
  "update.mode": "none",
  "editor.hideCursorInOverviewRuler": true,
  "terminal.integrated.shellIntegration.enabled": false,
  "terminal.integrated.lineHeight": 1.3,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.enableVisualBell": false,
  "scm.diffDecorations": "gutter",
  "workbench.activityBar.location": "top",
  "workbench.editor.empty.hint": "hidden",
  "editor.dropIntoEditor.preferences": [],
  "editor.pasteAs.preferences": [],
  "editor.parameterHints.enabled": false,
  "editor.hover.enabled": "on",
  "editor.suggest.showMethods": true,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "off"
  },
  "editor.suggestOnTriggerCharacters": false,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.inlineSuggest.enabled": false,
  "editor.cursorBlinking": "smooth",
  "editor.smoothScrolling": true,
  "chat.titleBar.signIn.enabled": false,
  "workbench.browser.showInTitleBar": false,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "chat.viewSessions.enabled": false,
  "chat.contextUsage.enabled": false,
  "chat.disableAIFeatures": true, //remove the chat with agent feature
  "workbench.browser.openLocalhostLinks": false,
  // "search.searchOnType": false
  //Minimize telemetry
  "telemetry.telemetryLevel": "off",
  "workbench.enableExperiments": false,
  "workbench.tips.enabled": false,
  "git.autofetch": false,
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,
  "C_Cpp.loggingLevel": "Warning"
}
